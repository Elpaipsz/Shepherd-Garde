# ──────────────────────────────────────────────
# Shepherd Garde — .gitignore
# ──────────────────────────────────────────────

# CRITICAL: Environment files with secrets
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.pyo
htmlcov/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml

# Django
*.log
local_settings.py
db.sqlite3
media/
staticfiles/

# Virtual environments
venv/
env/
.venv/
ENV/

# Node / Next.js
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/npm-debug.log*

# Docker volumes (not needed in repo)
postgres_data/

# IDEs
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
